---
import { site } from '../content/site.ts';
const { hero } = site;
---
<header class="relative px-3 md:px-6 pt-24 pb-20 sm:pt-32 sm:pb-28 max-w-[100ch] mx-auto">
  <h1 class="text-hero font-serif leading-[0.9] tracking-tight">
    {hero.title}
  </h1>

  <p class="mt-1 max-w-[40ch] text-lg md:text-3xl font-serif text-ink/80">
    {hero.tagline}
  </p>

  <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-baseline sm:gap-6">
    <p class="text-sm md:text-md uppercase tracking-[0.25em] text-muted">
      {hero.dates}
    </p>
    <p class="text-sm md:text-md uppercase tracking-[0.25em] text-muted">
      {hero.location}
    </p>
  </div>


  {/* Placeholder slot for hero graphic — replace later */}
  {/* <div class="mt-12 aspect-[3/2] bg-ink/5 rounded-sm" aria-hidden="true" /> */}
</header>
